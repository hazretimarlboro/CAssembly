; ============================================================
; complex.asm
; A showcase program for the custom toy CPU/ISA.
; Exercises every opcode: MOV (imm/reg), ADD, MUL, DIV, MOD,
; MVN, PUSH, POP, LOG, JMP, HLT.
;
; Note: this ISA has no CMP / conditional-jump instruction,
; only an unconditional JMP. That means a JMP-based loop can
; never decide on its own to stop. The trick used below is to
; pre-load the stack with a fixed batch of "work items" and
; let the loop body POP one per iteration -- once the stack is
; empty, the next POP raises STACK_UNDERFLOW, which the VM
; treats as a fatal trap and halts the program. That underflow
; is *intentional* here: it is this ISA's only available
; loop-exit mechanism.
; ============================================================

        JMP   start            ; unconditional jump over the dead block below

skipped:
        MOV   rax  9999         ; never executed -- proves JMP actually jumps
        LOG   rax
        HLT

start:
        ; ---- signed arithmetic via MVN ----
        MOV   rax  42
        MVN   rax               ; rax = -42 (two's complement negation)
        LOG   rax

        MOV   rbx  -7
        MVN   rbx               ; rbx = 7
        LOG   rbx

        ; ---- division / modulo, immediate form ----
        MOV   rcx  100
        DIV   rcx  7            ; rcx = 100 / 7 = 14
        LOG   rcx

        MOV   rdx  100
        MOD   rdx  7            ; rdx = 100 % 7 = 2
        LOG   rdx

        ; ---- register-register multiply ----
        MOV   rax  6
        MOV   rbx  7
        MUL   rax  rbx          ; rax = 42
        LOG   rax

        ; ---- stack-driven "loop": sum of squares of 1..5 ----
        MOV   rdx  0            ; rdx = running sum of squares

        PUSH  5
        PUSH  4
        PUSH  3
        PUSH  2
        PUSH  1

loop:
        POP   rax               ; when stack is empty this underflows and halts
        MOV   rbx  rax
        MUL   rbx  rax          ; rbx = rax^2
        ADD   rdx  rbx          ; rdx += rax^2
        LOG   rax
        LOG   rdx
        JMP   loop

        ; unreachable -- the loop only ever ends via STACK_UNDERFLOW
        HLT